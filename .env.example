# Datenbank (SQLite — Pfad zur gaeb.db)
# Standard: ./data/gaeb.db (relativ zum Projektordner)
# DB_PATH=/app/data/gaeb.db

# Easyjob Live-Suche (OAuth2 Password Flow)
EJ_BASE_URL=http://EASYJOB-TEST:8008
EJ_USERNAME=your_username
EJ_PASSWORD=your_password

# Easyjob Datenbank (pyodbc – direkter DB-Zugriff)
EJ_DB_SERVER=EASYJOB-TEST\SQLEXPRESS
EJ_DB_NAME=easyjob
EJ_DB_UID=sa
EJ_DB_PWD=your_db_password

# Session-Sicherheit (beliebigen langen String setzen)
SESSION_SECRET=change-me-to-a-long-random-string

# Claude API (optional – nur für Fallback-Matching benötigt)
ANTHROPIC_API_KEY=sk-ant-...
